<Project DefaultTargets="Build" xmlns="http://schemas.microsoft.com/developer/msbuild/2003" ToolsVersion="4.0">
  <PropertyGroup>
    <Configuration Condition=" '$(Configuration)' == '' ">Debug</Configuration>
    <SchemaVersion>2.0</SchemaVersion>
    <ProjectGuid>7cffa168-8ff1-4578-86c7-9cd77b23c6c0</ProjectGuid>
    <ProjectHome>.</ProjectHome>
    <StartupFile>
    </StartupFile>
    <SearchPath>
    </SearchPath>
    <WorkingDirectory>.</WorkingDirectory>
    <OutputPath>.</OutputPath>
    <Name>GeoAgent</Name>
    <RootNamespace>GeoAgent</RootNamespace>
    <InterpreterId>Global|VisualStudio|geo</InterpreterId>
  </PropertyGroup>
  <PropertyGroup Condition=" '$(Configuration)' == 'Debug' ">
    <DebugSymbols>true</DebugSymbols>
    <EnableUnmanagedDebugging>false</EnableUnmanagedDebugging>
  </PropertyGroup>
  <PropertyGroup Condition=" '$(Configuration)' == 'Release' ">
    <DebugSymbols>true</DebugSymbols>
    <EnableUnmanagedDebugging>false</EnableUnmanagedDebugging>
  </PropertyGroup>
  <ItemGroup>
    <InterpreterReference Include="Global|VisualStudio|geo" />
  </ItemGroup>
  <!-- ═══════════════════════════════════════════════════════════════ -->
  <!-- geoagent 包 — 根模块                                             -->
  <!-- ═══════════════════════════════════════════════════════════════ -->
  <ItemGroup>
    <Compile Include="src\geoagent\__init__.py" />
    <Compile Include="src\geoagent\version.py" />
    <Compile Include="src\geoagent\core.py" />
    <Compile Include="src\geoagent\workflow.py" />
    <Compile Include="src\geoagent\streamlit_app.py" />
    <Compile Include="src\geoagent\py_repl.py" />
    <Compile Include="src\geoagent\cli.py" />
  </ItemGroup>
  <!-- ═══════════════════════════════════════════════════════════════ -->
  <!-- geoagent.compiler 子包 — 三层收敛编译器                         -->
  <!-- ═══════════════════════════════════════════════════════════════ -->
  <ItemGroup>
    <Compile Include="src\geoagent\compiler\__init__.py" />
    <Compile Include="src\geoagent\compiler\task_schema.py" />
    <Compile Include="src\geoagent\compiler\intent_classifier.py" />
    <Compile Include="src\geoagent\compiler\task_executor.py" />
    <Compile Include="src\geoagent\compiler\compiler.py" />
  </ItemGroup>
  <!-- ═══════════════════════════════════════════════════════════════ -->
  <!-- geoagent.tools 子包                                             -->
  <!-- ═══════════════════════════════════════════════════════════════ -->
  <ItemGroup>
    <Compile Include="src\geoagent\tools\__init__.py" />
    <Compile Include="src\geoagent\tools\registry.py" />
    <Compile Include="src\geoagent\tools\arcgis_tools.py" />
    <Compile Include="src\geoagent\tools\tool_rag.py" />
  </ItemGroup>
  <!-- ═══════════════════════════════════════════════════════════════ -->
  <!-- geoagent.plugins 子包                                           -->
  <!-- ═══════════════════════════════════════════════════════════════ -->
  <ItemGroup>
    <Compile Include="src\geoagent\plugins\__init__.py" />
    <Compile Include="src\geoagent\plugins\base.py" />
    <Compile Include="src\geoagent\plugins\osm_plugin.py" />
    <Compile Include="src\geoagent\plugins\amap_plugin.py" />
  </ItemGroup>
  <!-- ═══════════════════════════════════════════════════════════════ -->
  <!-- geoagent.knowledge 子包                                         -->
  <!-- ═══════════════════════════════════════════════════════════════ -->
  <ItemGroup>
    <Compile Include="src\geoagent\knowledge\__init__.py" />
    <Compile Include="src\geoagent\knowledge\knowledge_rag.py" />
  </ItemGroup>
  <!-- ═══════════════════════════════════════════════════════════════ -->
  <!-- geoagent.gis_tools 子包                                         -->
  <!-- ═══════════════════════════════════════════════════════════════ -->
  <ItemGroup>
    <Compile Include="src\geoagent\gis_tools\__init__.py" />
    <Compile Include="src\geoagent\gis_tools\raster_ops.py" />
    <Compile Include="src\geoagent\gis_tools\gis_task_tools.py" />
    <Compile Include="src\geoagent\gis_tools\fixed_tools.py" />
    <Compile Include="src\geoagent\gis_tools\advanced_tools.py" />
  </ItemGroup>
  <!-- ═══════════════════════════════════════════════════════════════ -->
  <!-- 项目根目录脚本                                                  -->
  <!-- ═══════════════════════════════════════════════════════════════ -->
  <ItemGroup>
    <Compile Include="app.py" />
    <Compile Include="_fix_app.py" />
    <Compile Include="_fix_osm.py" />
    <Compile Include="diagnose_agent.py" />
    <Compile Include="test_py_repl.py" />
    <Compile Include="test_tools_quick.py" />
  </ItemGroup>
  <!-- ═══════════════════════════════════════════════════════════════ -->
  <!-- 测试文件                                                        -->
  <!-- ═══════════════════════════════════════════════════════════════ -->
  <ItemGroup>
    <Compile Include="tests\__init__.py" />
    <Compile Include="tests\conftest.py" />
    <Compile Include="tests\test_geoagent.py" />
    <Compile Include="tests\test_compiler.py" />
  </ItemGroup>
  <!-- ═══════════════════════════════════════════════════════════════ -->
  <!-- 配置文件                                                        -->
  <!-- ═══════════════════════════════════════════════════════════════ -->
  <ItemGroup>
    <Content Include="pyproject.toml" />
    <Content Include="pytest.ini" />
    <Content Include="README.md" />
    <Content Include=".env.example" />
    <Content Include=".gitignore" />
  </ItemGroup>
  <ItemGroup>
    <Folder Include="src\" />
    <Folder Include="src\geoagent\" />
    <Folder Include="src\geoagent\gis_tools\" />
    <Folder Include="src\geoagent\knowledge\" />
    <Folder Include="src\geoagent\plugins\" />
    <Folder Include="src\geoagent\tools\" />
    <Folder Include="src\geoagent\compiler\" />
    <Folder Include="tests\" />
  </ItemGroup>
  <Import Project="$(MSBuildExtensionsPath32)\Microsoft\VisualStudio\v$(VisualStudioVersion)\Python Tools\Microsoft.PythonTools.targets" />
  <Target Name="BeforeBuild">
  </Target>
  <Target Name="AfterBuild">
  </Target>
</Project>
