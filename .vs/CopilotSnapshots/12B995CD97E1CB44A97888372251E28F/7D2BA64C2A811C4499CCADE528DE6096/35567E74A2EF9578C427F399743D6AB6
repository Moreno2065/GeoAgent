                },
                "required": ["lat", "lon", "radius_m"]
            }
        }
    }
]

def _normalize_message_item(item):
    """
    把不同来源的消息统一为 dict(role: str, content: str)。
    - 如果是 dict 且 content 不是 str，则把 content 序列化为 JSON 字符串。
    - 如果是模型对象（含 .content 属性），读取其 .role 和 .content 并保证为字符串。
    - 否则把对象 stringify 为 content。
    """
    if isinstance(item, dict):
        role = str(item.get("role", "user"))
        content = item.get("content", "")
        if not isinstance(content, str):
            try:
                content = json.dumps(content, ensure_ascii=False)
            except Exception:
                content = str(content)
        return {"role": role, "content": content}
    # 兼容 OpenAI SDK 的 ChatCompletionMessage-like 对象
    if hasattr(item, "content") or hasattr(item, "role"):
        role = getattr(item, "role", "assistant") or "assistant"
        content = getattr(item, "content", "")
        if content is None:
            content = ""
        if not isinstance(content, str):
            try:
                content = json.dumps(content, ensure_ascii=False)
            except Exception:
                content = str(content)
        return {"role": str(role), "content": content}
    # 兜底：强制字符串化
    return {"role": "user", "content": str(item)}

def _normalize_messages(messages):
    normalized = []
    for m in messages:
        if isinstance(m, dict) and m.get("role") == "tool":
            # 保留 tool 消息的所有必需字段
            item = {
                "role": m.get("role"),
                "tool_call_id": m.get("tool_call_id"),
                "name": m.get("name"),
                "content": m.get("content")
            }
        else:
            item = _normalize_message_item(m)
        normalized.append(item)
    # 简单校验
    for i, m in enumerate(normalized):
        if not isinstance(m, dict) or not isinstance(m.get("role"), str):
            raise ValueError(f"Invalid message at index {i}: {m}")
        if m.get("role") == "tool":
            if not m.get("tool_call_id") or not m.get("name") or not isinstance(m.get("content"), str):
                raise ValueError(f"Invalid tool message at index {i}: missing tool_call_id/name/content: {m}")
        elif not isinstance(m.get("content"), str):
            raise ValueError(f"Invalid message at index {i}: content must be string: {m}")
    return normalized

def run_geo_agent(user_input: str):
    print(f"\n🗣️ 你: {user_input}")

    messages = [{"role": "user", "content": user_input}]
    response = client.chat.completions.create(
        model="deepseek-chat",
        messages=_normalize_messages(messages),
        tools=tools,
        tool_choice="auto",
    )

    response_message = response.choices[0].message

    if hasattr(response_message, "tool_calls") and response_message.tool_calls:
        tool_call = response_message.tool_calls[0]

        try:
            args = json.loads(tool_call.function.arguments)
            print(f"🤖 尝试调用工具，参数: {args}")

            function_result = buffer(
                lat=float(args.get("lat")),
                lon=float(args.get("lon")),
                radius_m=int(args.get("radius_m"))
            )
        except Exception as e:
            # 返回结构化的字符串（便于模型读取），同时保留日志中原始异常
            function_result = json.dumps({"error": True, "message": str(e)}, ensure_ascii=False)
            print(f"⚠️ 发生错误，已将报错信息反馈给大模型自我修正。 原始异常: {e}")

        # 不直接 append SDK 的模型对象，也不要把 dict 作为 content 直接放入
        messages.append({"role": "assistant", "content": response_message.content})
        # 将 function_result 强制为字符串（若是 dict 则 JSON 序列化）
        content_value = function_result if isinstance(function_result, str) else json.dumps(function_result, ensure_ascii=False)
        messages.append({
            "role": "tool",
            "tool_call_id": tool_call.id,
            "name": tool_call.function.name,
            "content": content_value,
        })

        final_response = client.chat.completions.create(
            model="deepseek-chat",
            messages=_normalize_messages(messages),
            tools=tools,
        )
        print(f"Deepseek'': {final_response.choices[0].message.content}")

if __name__ == "__main__":
    prompt = "帮我评估一下上海外滩（纬度 31.2397，经度 121.4896）周边 800 米的辐射范围，生成一个地图给我。"
    run_geo_agent(prompt)